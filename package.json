{
  "name": "demo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:styles",
    "build:styles": "sass styles/main.scss styles.css --load-path=styles",
    "watch:styles": "sass --watch styles/main.scss styles.css --load-path=styles",
    "prestart": "npm run build:styles && npm run stop",
    "start": "nodemon server.js",
    "dev": "npm start",
    "stop": "lsof -ti :3847 | xargs kill -9 2>/dev/null || true",
    "restart": "npm run stop && npm start"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "chokidar": "^5.0.0",
    "nodemon": "^3.1.14",
    "sass": "^1.83.0"
  }
}
